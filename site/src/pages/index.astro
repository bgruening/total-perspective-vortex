---
import "../styles/global.css";

const links = [
  {
    label: "Read the Docs",
    href: "https://total-perspective-vortex.readthedocs.io/",
    text: "Install TPV, configure Galaxy, and learn the full YAML model."
  },
  {
    label: "GitHub source",
    href: "https://github.com/galaxyproject/total-perspective-vortex",
    text: "Browse the Python package, tests, issues, and release history."
  },
  {
    label: "Shared resource database",
    href: "https://github.com/galaxyproject/tpv-shared-database/",
    text: "Use community-curated defaults for common bioinformatics tools."
  },
  {
    label: "Galaxy Training Network",
    href: "https://training.galaxyproject.org/training-material/topics/admin/tutorials/job-destinations/tutorial.html",
    text: "Follow the administrator tutorial for Galaxy job destinations."
  },
  {
    label: "Published paper",
    href: "https://doi.org/10.1007/s42979-026-04947-0",
    text: "Read the TPV paper on resource allocation and production results."
  },
  {
    label: "Galaxy Project",
    href: "https://galaxyproject.org/",
    text: "Learn about the open platform TPV was built to support."
  }
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta
      name="description"
      content="Total Perspective Vortex helps Galaxy right-size compute resources and route jobs across heterogeneous destinations."
    />
    <title>Total Perspective Vortex | Galaxy job routing and resource right-sizing</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Atkinson+Hyperlegible:wght@400;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <div class="site-shell">
      <header class="topbar" aria-label="Site navigation">
        <div class="topbar-inner">
          <a class="brand-link" href="/" aria-label="Total Perspective Vortex home">
            <img src="/tpv-logo-wide.png" alt="Total Perspective Vortex" />
          </a>
          <nav class="nav-links" aria-label="Primary navigation">
            <a href="#what">What it does</a>
            <a href="#impact">Impact</a>
            <a href="#database">Shared database</a>
            <a href="#learn">Learn more</a>
          </nav>
        </div>
      </header>

      <main>
        <section class="hero">
          <div class="hero-inner">
            <div>
              <p class="eyebrow">Galaxy resource intelligence</p>
              <h1>Total Perspective Vortex</h1>
              <p class="hero-copy">
                TPV is a Galaxy-integrated Python library for <strong>right-sizing</strong> job
                resources and <strong>meta-scheduling</strong> work across heterogeneous
                compute destinations using transparent YAML rules.
              </p>
              <div class="cta-row">
                <a class="button button-primary" href="https://total-perspective-vortex.readthedocs.io/">
                  Read the Docs
                </a>
                <a class="button button-secondary" href="https://github.com/galaxyproject/total-perspective-vortex">
                  View on GitHub
                </a>
              </div>
            </div>
            <aside class="hero-card" aria-label="TPV production summary">
              <img src="/tpv-logo.png" alt="TPV logo" />
              <div class="stat-grid">
                <div class="stat">
                  <strong>&gt;50 million</strong>
                  <span>of usegalaxy jobs scheduled in production</span>
                </div>
                <div class="stat">
                  <strong>~1,000</strong>
                  <span>tools covered by shared resource defaults</span>
                </div>
                <div class="stat">
                  <strong>15%</strong>
                  <span>queue wait reduction reported at Galaxy Australia</span>
                </div>
                <div class="stat">
                  <strong>ms</strong>
                  <span>scheduling decisions at production scale</span>
                </div>
              </div>
            </aside>
          </div>
        </section>

        <section id="what">
          <div class="section-inner">
            <p class="section-kicker">What TPV does</p>
            <h2 class="section-title">Policy-driven job routing for Galaxy administrators.</h2>
            <p class="section-lead">
              TPV sits at the Galaxy job dispatch layer. It combines tool, user, role, and
              destination rules to choose suitable resources and an execution target before
              the backend scheduler takes over.
            </p>
            <div class="cards">
              <article class="card card-accent">
                <h3>Right-size resources</h3>
                <p>
                  Set CPU, memory, GPU, environment, and scheduler parameters from reusable
                  defaults, expressions, and runtime rules.
                </p>
              </article>
              <article class="card">
                <h3>Route across destinations</h3>
                <p>
                  Match jobs to Slurm, Pulsar, local runners, clouds, or other configured
                  destinations based on capacity and policy.
                </p>
              </article>
              <article class="card">
                <h3>Keep policies transparent</h3>
                <p>
                  Express routing decisions through YAML entities, inheritance, tags, and
                  auditable Python expressions when more control is needed.
                </p>
              </article>
            </div>
          </div>
        </section>

        <section class="dark-section" id="impact">
          <div class="section-inner">
            <p class="section-kicker">How it is used</p>
            <h2 class="section-title">TPV is running across the usegalaxy federation.</h2>
            <p class="section-lead">
              Galaxy Australia, Europe, and the United States use TPV concepts in production
              to reduce over-allocation, route jobs through heterogeneous infrastructure, and
              make shared compute allocations go further.
            </p>
            <div class="workflow-panel">
              <ul class="feature-list">
                <li>
                  <strong>For researchers</strong>
                  Jobs can move through the system with fewer queue delays and fewer
                  resource-related failures, without changing the Galaxy interface.
                </li>
                <li>
                  <strong>For administrators</strong>
                  Common tool requirements are inherited once, then adjusted locally only
                  where a site has different hardware or policy constraints.
                </li>
                <li>
                  <strong>For infrastructure providers</strong>
                  TPV helps avoid over-allocation and supports more efficient use of shared
                  HPC, cloud, and institutional resources.
                </li>
              </ul>
              <img src="/job-dispatch-process.svg" alt="TPV job dispatch process diagram" />
            </div>
          </div>
        </section>

        <section id="database">
          <div class="section-inner">
            <p class="section-kicker">Shared resource database</p>
            <h2 class="section-title">Community defaults reduce repeated local tuning.</h2>
            <p class="section-lead">
              The TPV shared resource database captures empirically derived defaults for
              common bioinformatics tools. Galaxy sites can import the database, inherit
              maintained recommendations, and layer local overrides for site-specific
              destinations, limits, and policies.
            </p>
            <div class="cards">
              <article class="card">
                <h3>Curated centrally</h3>
                <p>
                  Defaults are maintained in version control by the Galaxy community and
                  informed by production use and targeted benchmarking.
                </p>
              </article>
              <article class="card card-accent">
                <h3>Overridden locally</h3>
                <p>
                  Sites can clamp resources to local hardware, add destination-specific
                  parameters, or override any inherited rule.
                </p>
              </article>
              <article class="card">
                <h3>Improved collaboratively</h3>
                <p>
                  Better rules can move from one deployment back into the shared database,
                  making production lessons reusable across Galaxy.
                </p>
              </article>
            </div>
          </div>
        </section>

        <section id="learn">
          <div class="section-inner">
            <p class="section-kicker">Learn more</p>
            <h2 class="section-title">This page is the overview. These are the canonical resources.</h2>
            <div class="link-grid">
              {
                links.map((link) => (
                  <a class="link-card" href={link.href}>
                    <strong>{link.label}</strong>
                    <span>{link.text}</span>
                  </a>
                ))
              }
            </div>
          </div>
        </section>
      </main>

      <footer>
        <div class="footer-inner">
          <span>Total Perspective Vortex is part of the Galaxy Project ecosystem.</span>
          <a href="https://galaxyproject.org/">galaxyproject.org</a>
        </div>
      </footer>
    </div>
  </body>
</html>
